{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "release1.capacity.run_config.schema.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "gate_config_sha256",
    "execution"
  ],
  "properties": {
    "schema_version": {
      "const": "release1.capacity.run_config.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "gate_config_sha256": {
      "type": "string",
      "minLength": 64
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "server",
        "stress_runner"
      ],
      "properties": {
        "server": {
          "$ref_local": "execution_target"
        },
        "stress_runner": {
          "$ref_local": "execution_target"
        }
      }
    }
  },
  "definitions": {
    "execution_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executable_path",
        "argv",
        "working_directory",
        "binary_sha256",
        "environment",
        "ulimit"
      ],
      "properties": {
        "executable_path": {
          "type": "string",
          "minLength": 1
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "working_directory": {
          "type": "string",
          "minLength": 1
        },
        "binary_sha256": {
          "type": "string",
          "minLength": 64
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "LANG": {
              "type": "string"
            },
            "LC_ALL": {
              "type": "string"
            },
            "LOL_CONFIG": {
              "type": "string"
            },
            "LOL_ENV": {
              "type": "string"
            },
            "PATH": {
              "type": "string"
            },
            "TZ": {
              "type": "string"
            }
          }
        },
        "ulimit": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    }
  }
}
